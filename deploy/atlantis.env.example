# atlantis — production environment template
# Copy to /etc/atlantis/atlantis.env, fill the secrets, then `chmod 600`.
# The systemd unit (deploy/atlantis.service) loads this via docker --env-file.
# See .env.example for the full list of tunable knobs and their defaults.

# Postgres — host-native on this box, reached over the host network namespace.
PG_URL=postgres://atlantis:CHANGEME@127.0.0.1:5432/atlantis?sslmode=disable

# Memcached — host-native.
MEMCACHED_ADDR=127.0.0.1:11211

# mTLS material. All three required together; the server enforces
# RequireAndVerifyClientCert and derives the caller identity from the client
# cert CN. server.key must be readable by the container user (uid 10001).
TLS_CERT_FILE=/etc/atlantis/tls/server.crt
TLS_KEY_FILE=/etc/atlantis/tls/server.key
TLS_CA_FILE=/etc/atlantis/tls/ca.crt

# Prod safety: schema changes flow through CI, not arbitrary callers.
ATL_ALLOW_APPLY_MUTATION=false

# Prod runs migrations explicitly (make migrate-up), not on boot.
AUTO_MIGRATE=false

LOG_LEVEL=info
